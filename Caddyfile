{$DOMAIN} {
    # Use Caddy's internal CA for local / dev domains (letsencrypt won't issue for .local).
    # Remove this line in production to allow automatic Let's Encrypt issuance.
    tls internal

    # Reverse proxy to the .NET app
    reverse_proxy app:8080

    # Enable gzip compression
    encode gzip zstd

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        X-XSS-Protection "1; mode=block"
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        -Server
    }

    # Logging
    log {
        output file /data/access.log {
            roll_size 10mb
            roll_keep 5
        }
    }
}
