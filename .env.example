# ============================================================
# LegalRO Production Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   nano .env
# ============================================================

# Your domain name (DNS must point to this server)
DOMAIN=legalro.your-domain.com

# SQL Server SA password (change this!)
# Must be strong: 8+ chars, uppercase, lowercase, digit, special char
DB_PASSWORD=YourStrongP@ssw0rd!Change_Me

# JWT secret key (generate a random 64+ character string)
# Example: openssl rand -base64 64
JWT_SECRET_KEY=CHANGE_ME_GenerateAStrongRandomSecretKeyAtLeast64CharactersLong!!

# Azure OpenAI (optional - for AI legal research features)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
