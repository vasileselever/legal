# ============================================================
# LegalRO Production Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   nano .env
# ============================================================

# Your domain name (DNS must point to this server)
DOMAIN=legalro.your-domain.com

# SQL Server SA password (change this!)
# Must be strong: 8+ chars, uppercase, lowercase, digit, special char
DB_PASSWORD=SaN3wP@ssw0rd!2026

# JWT secret key (generate a random 64+ character string)
# Example: openssl rand -base64 64
JWT_SECRET_KEY=CHANGE_ME_GenerateAStrongRandomSecretKeyAtLeast64CharactersLong!!

# Azure OpenAI (optional - for AI legal research features)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Seed database with test data on first startup (set to false after first deploy)
SeedDatabase=true

# Firm GUID for the public intake form (get from DB after first registration)
# Without this, the public contact form cannot submit leads
VITE_FIRM_ID=

# ?? Email notifications ???????????????????????????????????????????????????????
# Option A: SMTP (Gmail, Outlook, your own server, etc.)
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=your-app-password

# Option B: SendGrid
SENDGRID_ENABLED=false
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=contact@legalro.ro
SENDGRID_FROM_NAME=Cabinet Avocat LegalRO

# Firm display name & reply-to address used in all outgoing emails
FIRM_NAME=Cabinet Avocat LegalRO
FIRM_EMAIL=contact@legalro.ro
